Options -Indexes -MultiViews
ServerSignature Off

# Force HTTPS (aktifkan di production)
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Front Controller
RewriteEngine On
RewriteBase /

# Block access to hidden files
RewriteRule (^|/)\.          - [F,L]
# Block access to config/core files
RewriteRule ^config/         - [F,L]
RewriteRule ^core/           - [F,L]
RewriteRule ^app/            - [F,L]
RewriteRule ^storage/        - [F,L]
RewriteRule ^vendor/         - [F,L]

# Allow static assets
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]

# Security headers (jika tidak di-handle PHP)
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
</IfModule>

# Block bad bots
<IfModule mod_rewrite.c>
    RewriteCond %{HTTP_USER_AGENT} (sqlmap|nikto|nmap|masscan) [NC,OR]
    RewriteCond %{HTTP_USER_AGENT} (wget|curl|python-requests) [NC]
    RewriteRule .* - [F,L]
</IfModule>

# Limit request size (10MB)
<IfModule mod_php.c>
    php_value upload_max_filesize 10M
    php_value post_max_size 10M
    php_value memory_limit 128M
    php_value max_execution_time 60
</IfModule>
